{
	"name": "@lynq/stripe",
	"version": "0.1.0",
	"description": "Stripe Checkout payment provider for lynq MCP framework.",
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs"
		}
	},
	"files": ["dist"],
	"scripts": {
		"build": "tsup",
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "pnpm build"
	},
	"dependencies": {
		"@lynq/lynq": "workspace:^"
	},
	"peerDependencies": {
		"stripe": "^17.0.0 || ^18.0.0 || ^19.0.0 || ^20.0.0"
	},
	"peerDependenciesMeta": {
		"stripe": {
			"optional": true
		}
	},
	"devDependencies": {
		"stripe": "^20.4.1",
		"tsup": "^8.0.0",
		"typescript": "^5.6.0",
		"vitest": "^2.0.0",
		"zod": "^3.24.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/hogekai/lynq",
		"directory": "packages/stripe"
	},
	"license": "MIT",
	"engines": {
		"node": ">=18"
	}
}
