{
	"name": "@lynq/express",
	"version": "0.1.1",
	"description": "Express adapter for lynq MCP framework.",
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.mjs"
		}
	},
	"files": ["dist"],
	"scripts": {
		"build": "tsup",
		"test": "vitest run",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "pnpm build"
	},
	"dependencies": {
		"@lynq/lynq": "workspace:^"
	},
	"peerDependencies": {
		"express": "^5.0.0",
		"@lynq/github": "^0.1.0",
		"@lynq/google": "^0.1.0",
		"@lynq/stripe": "^0.1.0",
		"@lynq/crypto": "^0.1.0"
	},
	"peerDependenciesMeta": {
		"@lynq/github": { "optional": true },
		"@lynq/google": { "optional": true },
		"@lynq/stripe": { "optional": true },
		"@lynq/crypto": { "optional": true }
	},
	"devDependencies": {
		"@lynq/github": "workspace:^",
		"@lynq/google": "workspace:^",
		"@lynq/stripe": "workspace:^",
		"@lynq/crypto": "workspace:^",
		"@types/express": "^5.0.6",
		"express": "^5.2.1",
		"tsup": "^8.0.0",
		"typescript": "^5.6.0",
		"vitest": "^2.0.0"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/hogekai/lynq",
		"directory": "packages/express"
	},
	"license": "MIT",
	"engines": {
		"node": ">=18"
	}
}
