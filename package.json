			"types": "./dist/middleware/rate-limit.d.ts",
			"import": "./dist/middleware/rate-limit.mjs"
		},
		"./truncate": {
			"types": "./dist/middleware/truncate.d.ts",
			"import": "./dist/middleware/truncate.mjs"
