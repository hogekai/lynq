			"types": "./dist/middleware/bearer.d.ts",
			"import": "./dist/middleware/bearer.mjs"
		},
		"./jwt": {
			"types": "./dist/middleware/jwt.d.ts",
			"import": "./dist/middleware/jwt.mjs"
		},
		"./github": {
			"types": "./dist/middleware/github.d.ts",
			"import": "./dist/middleware/github.mjs"
		},
		"./github-oauth": {
			"types": "./dist/middleware/github.d.ts",
			"import": "./dist/middleware/github.mjs"
		},
		"./google": {
			"types": "./dist/middleware/google.d.ts",
			"import": "./dist/middleware/google.mjs"
		},
		"./google-oauth": {
			"types": "./dist/middleware/google.d.ts",
			"import": "./dist/middleware/google.mjs"
		},
		"./stripe": {
			"types": "./dist/middleware/stripe.d.ts",
			"import": "./dist/middleware/stripe.mjs"
		},
		"./crypto": {
			"types": "./dist/middleware/crypto.d.ts",
			"import": "./dist/middleware/crypto.mjs"
		},
		"./usdc": {
			"types": "./dist/middleware/crypto.d.ts",
			"import": "./dist/middleware/crypto.mjs"
		},
		"./tip": {
			"types": "./dist/middleware/tip.d.ts",
			"import": "./dist/middleware/tip.mjs"
		},
		"./store": {
			"types": "./dist/store.d.ts",
			"import": "./dist/store.mjs"
		}
	},
	"files": [
		"dist"
	],
	"sideEffects": false,
	"scripts": {
		"build": "tsup",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check src tests",
		"lint:fix": "biome check --write src tests",
		"typecheck": "tsc --noEmit",
		"docs:api": "typedoc",
		"docs:dev": "vitepress dev docs",
		"docs:build": "vitepress build docs",
		"docs:preview": "vitepress preview docs",
		"prepublishOnly": "pnpm build"
	},
	"dependencies": {
		"@modelcontextprotocol/sdk": "^1.27.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/express": "^5.0.6",
		"express": "^5.2.1",
		"hono": "^4.12.5",
		"jose": "^6.2.1",
		"stripe": "^20.4.1",
		"tsup": "^8.0.0",
		"typedoc": "^0.28.17",
		"typedoc-plugin-markdown": "^4.10.0",
		"typescript": "^5.6.0",
		"vitepress": "^1.6.4",
		"vitest": "^2.0.0",
		"zod": "^3.24.0"
	},
	"peerDependencies": {
		"express": "^5.0.0",
		"hono": "^4.0.0",
		"jose": "^6.0.0",
		"stripe": "^17.0.0 || ^18.0.0 || ^19.0.0 || ^20.0.0",
		"zod": "^3.0.0"
	},
	"peerDependenciesMeta": {
		"zod": {
			"optional": true
		},
		"hono": {
			"optional": true
		},
		"express": {
			"optional": true
		},
		"jose": {
			"optional": true
		},
		"stripe": {
			"optional": true
		}
	},
	"publishConfig": {
		"access": "public"
	},
	"keywords": [
		"mcp",
		"model-context-protocol",
		"framework",
		"middleware",
		"ai",
		"agent"
	],
	"repository": {
		"type": "git",
		"url": "https://github.com/hogekai/lynq"
	},
	"bugs": {
		"url": "https://github.com/hogekai/lynq/issues"
	},
	"homepage": "https://github.com/hogekai/lynq#readme",
	"license": "MIT",
	"engines": {
		"node": ">=18"
	},
	"packageManager": "pnpm@10.30.1",
	"pnpm": {
		"onlyBuiltDependencies": [
			"@biomejs/biome",
			"esbuild"
		]
	}
}
